{
  "name": "boyar-matrimony-backend",
  "version": "1.0.0",
  "description": "Backend API for Vijayalakshmi Boyar Matrimony App",
  "main": "server.js",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "start": "node --no-deprecation server.js",
    "dev": "nodemon --no-deprecation server.js",
    "test": "jest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.js",
    "postinstall": "echo 'Run: npm install tesseract.js sharp @aws-sdk/client-rekognition @aws-sdk/client-s3'"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.400.0",
    "@aws-sdk/client-s3": "^3.400.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^10.0.4",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.15.2",
    "razorpay": "^2.9.6",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.0.4",
    "twilio": "^4.23.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/multer": "^2.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.22.0",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "matrimony",
    "api",
    "boyar",
    "community"
  ],
  "author": "Vijayalakshmi Jayakumar",
  "license": "MIT"
}
