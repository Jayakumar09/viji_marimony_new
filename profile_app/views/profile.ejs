<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile Details - Vijayalakshmi Boyar Matrimony</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f5f5f5;
            font-family: 'Segoe UI', Arial, sans-serif;
        }
        .profile-container {
            max-width: 800px;
            margin: 30px auto;
            background: white;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            padding: 40px;
            position: relative;
            overflow: hidden;
        }
        /* Watermark tile pattern preview */
        .watermark-preview {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            pointer-events: none;
            z-index: 0;
            background: repeating-linear-gradient(
                45deg,
                transparent,
                transparent 290px,
                rgba(158, 158, 158, 0.03) 290px,
                rgba(158, 158, 158, 0.03) 580px
            );
        }
        .watermark-text {
            position: absolute;
            color: rgba(158, 158, 158, 0.12);
            font-size: 24px;
            font-weight: bold;
            white-space: nowrap;
            transform: rotate(-45deg) scale(0.7);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Helvetica-Bold', Arial, sans-serif;
            width: auto;
            display: block;
            text-align: center;
            opacity: 0.25;
        }
        .watermark-tile1 { top: 5%; left: -5%; }
        .watermark-tile2 { top: 15%; left: 20%; }
        .watermark-tile3 { top: 25%; left: -2%; }
        .watermark-tile4 { top: 35%; left: 25%; }
        .watermark-tile5 { top: 45%; left: 5%; }
        .watermark-tile6 { top: 55%; left: 30%; }
        .watermark-tile7 { top: 65%; left: 10%; }
        .watermark-tile8 { top: 75%; left: 35%; }
        .watermark-tile9 { top: 85%; left: 15%; }
        .watermark-tile10 { top: 95%; left: 40%; }
        
        .content {
            position: relative;
            z-index: 1;
            background: transparent;
        }
        h1 {
            color: #333;
            font-size: 32px;
            font-weight: 600;
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 2px solid #ff6b6b;
        }
        h2 {
            color: #ff6b6b;
            font-size: 20px;
            font-weight: 600;
            margin: 25px 0 15px 0;
            padding-left: 10px;
            border-left: 4px solid #ff6b6b;
        }
        .info-row {
            margin-bottom: 8px;
            font-size: 15px;
            line-height: 1.6;
        }
        .info-label {
            font-weight: 600;
            color: #555;
            display: inline-block;
            width: 150px;
        }
        .info-value {
            color: #333;
        }
        .profile-image {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #ff6b6b;
            margin: 0 auto 20px;
            display: block;
        }
        .image-upload-btn {
            position: absolute;
            bottom: 0;
            right: 50%;
            transform: translateX(50%);
            background: #ff6b6b;
            color: white;
            border: none;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border: 2px solid white;
        }
        .btn-primary {
            background-color: #ff6b6b;
            border-color: #ff6b6b;
        }
        .btn-primary:hover {
            background-color: #ff5252;
            border-color: #ff5252;
        }
        .btn-success {
            background-color: #25D366;
            border-color: #25D366;
        }
        .matrimony-badge {
            background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
            color: white;
            padding: 8px 25px;
            border-radius: 25px;
            font-size: 16px;
            font-weight: 600;
            text-align: center;
            margin-bottom: 20px;
            display: inline-block;
        }
        .parameter-badge {
            background: #f8f9fa;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 25px;
            font-size: 13px;
            color: #666;
            border: 1px solid #e9ecef;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
        }
        .param-item {
            background: white;
            padding: 5px 12px;
            border-radius: 20px;
            border: 1px solid #dee2e6;
            font-family: monospace;
        }
        .footer-note {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid #eee;
            text-align: center;
            color: #999;
            font-size: 12px;
        }
        .gallery-image {
            width: 100%;
            height: 100px;
            object-fit: cover;
            border-radius: 5px;
            border: 1px solid #dee2e6;
        }
        .delete-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(220,53,69,0.9);
            color: white;
            border: none;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
        }
        .toast-message {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #333;
            color: white;
            padding: 12px 24px;
            border-radius: 5px;
            z-index: 9999;
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    </style>
</head>
<body>
    <div class="profile-container">
        <!-- Watermark Tile Pattern -->
        <div class="watermark-preview"></div>
        <div class="watermark-text watermark-tile1">VIJAYALAKSHMI BOYAR MATRIMONY</div>
        <div class="watermark-text watermark-tile2">VIJAYALAKSHMI BOYAR MATRIMONY</div>
        <div class="watermark-text watermark-tile3">VIJAYALAKSHMI BOYAR MATRIMONY</div>
        <div class="watermark-text watermark-tile4">VIJAYALAKSHMI BOYAR MATRIMONY</div>
        <div class="watermark-text watermark-tile5">VIJAYALAKSHMI BOYAR MATRIMONY</div>
        <div class="watermark-text watermark-tile6">VIJAYALAKSHMI BOYAR MATRIMONY</div>
        <div class="watermark-text watermark-tile7">VIJAYALAKSHMI BOYAR MATRIMONY</div>
        <div class="watermark-text watermark-tile8">VIJAYALAKSHMI BOYAR MATRIMONY</div>
        <div class="watermark-text watermark-tile9">VIJAYALAKSHMI BOYAR MATRIMONY</div>
        <div class="watermark-text watermark-tile10">VIJAYALAKSHMI BOYAR MATRIMONY</div>

        <!-- Main Content -->
        <div class="content">
            <!-- Parameters Display -->
            <div class="parameter-badge">
                <span class="param-item">🔤 24px</span>
                <span class="param-item">🎨 25% opacity</span>
                <span class="param-item">📏 ×0.7 scale</span>
                <span class="param-item">🔄 -45° rotation</span>
                <span class="param-item">🧩 Tile pattern</span>
                <span class="param-item">📐 290px spacing</span>
            </div>

            <div class="text-center">
                <span class="matrimony-badge">VIJAYALAKSHMI BOYAR MATRIMONY</span>
            </div>
            
            <h1>Profile Details</h1>

            <% if (profile) { %>
                <!-- Profile Image Section -->
                <div class="text-center position-relative mb-4">
                    <img src="<%= profile.profileImage || 'https://via.placeholder.com/120?text=Profile' %>" 
                         class="profile-image" id="profileImage" alt="Profile">
                    <button class="image-upload-btn" onclick="document.getElementById('profileImageInput').click()">
                        <i class="bi bi-camera-fill"></i>
                    </button>
                    <input type="file" id="profileImageInput" accept="image/*" style="display: none;" 
                           onchange="uploadProfileImage(this)">
                </div>

                <!-- Personal Information -->
                <h2>Personal Information</h2>
                <div class="info-row"><span class="info-label">Full Name:</span> <span class="info-value"><%= profile.fullName %></span></div>
                <div class="info-row"><span class="info-label">Gender:</span> <span class="info-value"><%= profile.gender %></span></div>
                <div class="info-row"><span class="info-label">Date of Birth:</span> <span class="info-value"><%= profile.dateOfBirth %></span></div>
                <div class="info-row"><span class="info-label">Age:</span> <span class="info-value"><%= profile.age %> years</span></div>
                <div class="info-row"><span class="info-label">Blood Group:</span> <span class="info-value"><%= profile.bloodGroup %></span></div>
                <div class="info-row"><span class="info-label">Marital Status:</span> <span class="info-value"><%= profile.maritalStatus %></span></div>
                <div class="info-row"><span class="info-label">Religion:</span> <span class="info-value"><%= profile.religion %></span></div>
                <div class="info-row"><span class="info-label">Sub Caste:</span> <span class="info-value"><%= profile.subCaste %></span></div>

                <!-- Contact Information -->
                <h2>Contact Information</h2>
                <div class="info-row"><span class="info-label">Email:</span> <span class="info-value"><%= profile.email %></span></div>
                <div class="info-row"><span class="info-label">Phone:</span> <span class="info-value"><%= profile.phone %></span></div>
                <div class="info-row"><span class="info-label">Address:</span> <span class="info-value"><%= profile.address %></span></div>
                <div class="info-row"><span class="info-label">City:</span> <span class="info-value"><%= profile.city %></span></div>
                <div class="info-row"><span class="info-label">State:</span> <span class="info-value"><%= profile.state %></span></div>
                <div class="info-row"><span class="info-label">Country:</span> <span class="info-value"><%= profile.country %></span></div>
                <div class="info-row"><span class="info-label">Pincode:</span> <span class="info-value"><%= profile.pincode %></span></div>

                <!-- Education & Career -->
                <h2>Education & Career</h2>
                <div class="info-row"><span class="info-label">Education:</span> <span class="info-value"><%= profile.education %></span></div>
                <div class="info-row"><span class="info-label">Occupation:</span> <span class="info-value"><%= profile.occupation %></span></div>
                <div class="info-row"><span class="info-label">Company:</span> <span class="info-value"><%= profile.company %></span></div>
                <div class="info-row"><span class="info-label">Annual Income:</span> <span class="info-value">₹ <%= profile.annualIncome.toLocaleString('en-IN') %></span></div>

                <!-- Family Details -->
                <h2>Family Details</h2>
                <div class="info-row"><span class="info-label">Father Name:</span> <span class="info-value"><%= profile.fatherName %></span></div>
                <div class="info-row"><span class="info-label">Father Occupation:</span> <span class="info-value"><%= profile.fatherOccupation %></span></div>
                <div class="info-row"><span class="info-label">Mother Name:</span> <span class="info-value"><%= profile.motherName %></span></div>
                <div class="info-row"><span class="info-label">Mother Occupation:</span> <span class="info-value"><%= profile.motherOccupation %></span></div>
                <div class="info-row"><span class="info-label">Sisters:</span> <span class="info-value"><%= profile.sisters %> (Married: <%= profile.marriedSisters %>)</span></div>
                <div class="info-row"><span class="info-label">Family Type:</span> <span class="info-value"><%= profile.familyType %></span></div>
                <div class="info-row"><span class="info-label">Family Status:</span> <span class="info-value"><%= profile.familyStatus %></span></div>

                <!-- Physical Details -->
                <h2>Physical Details</h2>
                <div class="info-row"><span class="info-label"></span> <span class="info-value text-muted"><em>(Details to be added)</em></span></div>

                <!-- Gallery Section - FIXED -->
                <% if (gallery && gallery.length > 0) { %>
                    <h2>Gallery</h2>
                    <div class="row g-2 mb-4">
                        <% gallery.forEach(function(image) { %>
                            <div class="col-4 position-relative" id="gallery-<%= image.id %>">
                                <img src="<%= image.imagePath %>" class="gallery-image" alt="Gallery">
                                <button class="delete-btn" onclick="deleteImage('<%= image.id %>')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        <% }); %>
                    </div>
                <% } %>

                <!-- Action Buttons -->
                <div class="text-center mt-4">
                    <button class="btn btn-primary me-2" onclick="generatePDF()">
                        <i class="bi bi-file-pdf"></i> Download PDF
                    </button>
                    <button class="btn btn-success" onclick="shareViaWhatsApp()">
                        <i class="bi bi-whatsapp"></i> Share on WhatsApp
                    </button>
                </div>

                <!-- Add to Gallery Button -->
                <div class="text-center mt-3">
                    <button class="btn btn-outline-primary" onclick="document.getElementById('galleryInput').click()">
                        <i class="bi bi-plus-circle"></i> Add Photos to Gallery
                    </button>
                    <input type="file" id="galleryInput" accept="image/*" multiple style="display: none;" 
                           onchange="uploadGalleryImages(this)">
                </div>

                <!-- Footer with generated info -->
                <div class="footer-note">
                    Generated by Vijayalakshmi Boyar Matrimony<br>
                    Page 1 of 2 | <%= new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>, <%= new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                </div>

            <% } else { %>
                <div class="alert alert-warning text-center">
                    <i class="bi bi-exclamation-triangle"></i>
                    No profile found. Please check the database.
                </div>
            <% } %>
        </div>
    </div>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    
    <script>
        // Upload profile image
        function uploadProfileImage(input) {
            if (input.files && input.files[0]) {
                const formData = new FormData();
                formData.append('image', input.files[0]);

                fetch('/api/upload/profile-image', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('profileImage').src = data.imagePath + '?t=' + Date.now();
                        showToast('Profile image updated successfully!', 'success');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showToast('Error uploading image', 'error');
                });
            }
        }

        // Upload gallery images
        function uploadGalleryImages(input) {
            if (input.files && input.files.length > 0) {
                const promises = [];
                
                for (let i = 0; i < input.files.length; i++) {
                    const formData = new FormData();
                    formData.append('image', input.files[i]);
                    
                    promises.push(
                        fetch('/api/upload/gallery', {
                            method: 'POST',
                            body: formData
                        }).then(response => response.json())
                    );
                }

                Promise.all(promises)
                    .then(() => {
                        showToast('Gallery images uploaded successfully!', 'success');
                        setTimeout(() => location.reload(), 1000);
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showToast('Error uploading images', 'error');
                    });
            }
        }

        // Delete gallery image
        function deleteImage(id) {
            if (confirm('Are you sure you want to delete this image?')) {
                fetch(`/api/gallery/${id}`, {
                    method: 'DELETE'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById(`gallery-${id}`).remove();
                        showToast('Image deleted successfully', 'success');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showToast('Error deleting image', 'error');
                });
            }
        }

        // Generate PDF
        function generatePDF() {
            window.open('/api/generate-pdf', '_blank');
            showToast('Generating PDF...', 'info');
        }

        // Share via WhatsApp
        function shareViaWhatsApp() {
            const text = "Check out my profile on Vijayalakshmi Boyar Matrimony!";
            const url = window.location.href;
            window.open(`https://wa.me/?text=${encodeURIComponent(text + ' ' + url)}`, '_blank');
        }

        // Toast notification function
        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.className = 'toast-message';
            
            if (type === 'success') {
                toast.style.backgroundColor = '#28a745';
            } else if (type === 'error') {
                toast.style.backgroundColor = '#dc3545';
            } else {
                toast.style.backgroundColor = '#007bff';
            }
            
            toast.textContent = message;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 3000);
        }
    </script>
</body>
</html>